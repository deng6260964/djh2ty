<!-- pages/feedback/feedback.wxml -->
<view class="page-container">

  <!-- 加载骨架 -->
  <view wx:if="{{loading}}" class="list-content">
    <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="index">
      <view class="skeleton sk-date"></view>
      <view class="skeleton sk-label"></view>
      <view class="skeleton sk-text"></view>
      <view class="skeleton sk-text short"></view>
    </view>
  </view>

  <!-- 反馈列表 -->
  <view wx:elif="{{feedbackList.length > 0}}" class="list-content">
    <view
      wx:for="{{feedbackList}}"
      wx:key="id"
      class="feedback-card"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <!-- 卡片顶部 -->
      <view class="card-top">
        <view class="course-info">
          <view class="subject-badge">
            <text class="subject-text">{{item.courseLabel}}</text>
          </view>
          <text class="course-date">{{item.dateStr}}</text>
          <text class="course-time" wx:if="{{item.timeStr}}">{{item.timeStr}}</text>
        </view>
        <text class="view-all-arrow">›</text>
      </view>

      <!-- 反馈摘要 -->
      <view class="feedback-preview" wx:if="{{item.performancePreview}}">
        <text class="preview-label">本节课表现</text>
        <text class="preview-text">{{item.performancePreview}}</text>
      </view>

      <!-- 无摘要时 -->
      <view class="feedback-placeholder" wx:else>
        <text class="placeholder-text">点击查看完整反馈</text>
      </view>
    </view>

    <!-- 底部加载更多 -->
    <view class="load-more-wrap">
      <view wx:if="{{isLoadingMore}}" class="loading-more">
        <text class="loading-text">加载中...</text>
      </view>
      <view wx:elif="{{!hasMore && feedbackList.length > 0}}" class="no-more">
        <text class="no-more-text">已显示全部反馈</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!loading}}" class="empty-state">
    <text class="empty-icon">💬</text>
    <text class="empty-title">暂无课堂反馈</text>
    <text class="empty-desc">老师还未发送本次课程的反馈</text>
  </view>

</view>
