<!-- pages/feedback-detail/feedback-detail.wxml -->
<view class="page-container">

  <!-- 加载骨架 -->
  <view wx:if="{{loading}}" class="skeleton-wrap">
    <view class="skeleton-header-card">
      <view class="skeleton sk-title"></view>
      <view class="skeleton sk-meta"></view>
    </view>
    <view class="skeleton-content-card" wx:for="{{[1,2,3,4]}}" wx:key="index">
      <view class="skeleton sk-section-title"></view>
      <view class="skeleton sk-line"></view>
      <view class="skeleton sk-line long"></view>
      <view class="skeleton sk-line short"></view>
    </view>
  </view>

  <!-- 反馈详情 -->
  <block wx:elif="{{feedback}}">

    <!-- 顶部课程信息卡片 -->
    <view class="course-header-card">
      <view class="course-header-top">
        <view class="course-badge-wrap">
          <view class="subject-badge">
            <text class="subject-text">{{feedback.courseLabel}}</text>
          </view>
          <text class="course-date-text">{{feedback.dateStr}}</text>
        </view>
        <text class="feedback-time" wx:if="{{feedback.timeRange}}">{{feedback.timeRange}}</text>
      </view>

      <view class="feedback-meta-row">
        <text class="feedback-meta-label">反馈时间：</text>
        <text class="feedback-meta-value">{{feedback.createdDateStr}}</text>
      </view>
    </view>

    <!-- 四个反馈字段 -->

    <!-- 1. 本节课表现 -->
    <view class="feedback-section" wx:if="{{feedback.performance}}">
      <view class="section-header">
        <view class="section-icon performance-icon">
          <text class="icon-emoji">⭐</text>
        </view>
        <text class="section-title">本节课表现</text>
      </view>
      <view class="section-content">
        <rich-text nodes="{{feedback.performance}}" class="feedback-text"></rich-text>
      </view>
    </view>

    <!-- 2. 知识点掌握情况 -->
    <view class="feedback-section" wx:if="{{feedback.knowledge_mastery}}">
      <view class="section-header">
        <view class="section-icon knowledge-icon">
          <text class="icon-emoji">📖</text>
        </view>
        <text class="section-title">知识点掌握情况</text>
      </view>
      <view class="section-content">
        <rich-text nodes="{{feedback.knowledge_mastery}}" class="feedback-text"></rich-text>
      </view>
    </view>

    <!-- 3. 存在问题 -->
    <view class="feedback-section" wx:if="{{feedback.problems}}">
      <view class="section-header">
        <view class="section-icon problems-icon">
          <text class="icon-emoji">⚠️</text>
        </view>
        <text class="section-title">存在问题</text>
      </view>
      <view class="section-content">
        <rich-text nodes="{{feedback.problems}}" class="feedback-text"></rich-text>
      </view>
    </view>

    <!-- 4. 下节课计划 -->
    <view class="feedback-section" wx:if="{{feedback.next_plan}}">
      <view class="section-header">
        <view class="section-icon plan-icon">
          <text class="icon-emoji">🎯</text>
        </view>
        <text class="section-title">下节课计划</text>
      </view>
      <view class="section-content">
        <rich-text nodes="{{feedback.next_plan}}" class="feedback-text"></rich-text>
      </view>
    </view>

    <!-- 所有字段为空时 -->
    <view
      class="empty-feedback"
      wx:if="{{!feedback.performance && !feedback.knowledge_mastery && !feedback.problems && !feedback.next_plan}}"
    >
      <text class="empty-feedback-text">老师尚未填写详细反馈内容</text>
    </view>

    <!-- 底部时间戳 -->
    <view class="footer-info">
      <text class="footer-text">反馈由老师填写 · {{feedback.createdDateStr}}</text>
    </view>

  </block>

  <!-- 空状态 -->
  <view wx:elif="{{!loading}}" class="empty-state">
    <text class="empty-icon">💬</text>
    <text class="empty-title">反馈不存在</text>
    <text class="empty-desc">该反馈可能已被删除</text>
  </view>

</view>
