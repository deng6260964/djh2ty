/* pages/assignment-detail/assignment-detail.wxss */

.page-container {
  background: #F8FAFC;
  min-height: 100vh;
  padding-bottom: 80rpx;
}

/* 骨架屏 */
.skeleton-wrap {
  padding: 24rpx;
}

.skeleton-header {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.skeleton-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.skeleton {
  background: linear-gradient(90deg, #E5E7EB 25%, #F3F4F6 50%, #E5E7EB 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
  display: block;
  margin-bottom: 16rpx;
}

.skeleton-title-big {
  width: 70%;
  height: 40rpx;
}

.skeleton-meta {
  width: 50%;
  height: 28rpx;
}

.skeleton-line {
  width: 90%;
  height: 28rpx;
}

.skeleton-line.long {
  width: 100%;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 顶部作业信息 */
.assignment-header {
  background: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 0;
}

.assignment-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.header-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.subject-badge {
  background: #EFF6FF;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
}

.subject-text {
  font-size: 24rpx;
  color: #2563EB;
  font-weight: 500;
}

.status-badge {
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
}

.status-badge.pending {
  background: #FFFBEB;
}

.status-badge.pending .status-text {
  color: #F59E0B;
}

.status-badge.submitted {
  background: #ECFDF5;
}

.status-badge.submitted .status-text {
  color: #10B981;
}

.status-badge.graded {
  background: #EFF6FF;
}

.status-badge.graded .status-text {
  color: #2563EB;
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
}

.date-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.date-item {
  font-size: 24rpx;
  color: #6B7280;
}

.date-item.urgent {
  color: #EF4444;
  font-weight: 500;
}

.date-separator {
  color: #D1D5DB;
}

.due-tip {
  margin-top: 8rpx;
}

.due-tip-text {
  font-size: 24rpx;
  font-weight: 600;
}

/* 分区分隔 */
.section-divider {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx 12rpx;
  background: #F8FAFC;
  border-top: 1rpx solid #E5E7EB;
  border-bottom: 1rpx solid #E5E7EB;
}

.section-label {
  font-size: 26rpx;
  color: #374151;
  font-weight: 600;
}

.section-date {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 作业内容 */
.content-section {
  background: #FFFFFF;
  padding: 32rpx;
  min-height: 200rpx;
}

.rich-content {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
}

.plain-content {
  font-size: 28rpx;
  color: #9CA3AF;
}

/* 批改结果 */
.grade-section {
  background: #FFFFFF;
  padding: 32rpx;
}

.score-display {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.score-wrap {
  display: flex;
  align-items: baseline;
  flex: 1;
}

.score-number {
  font-size: 80rpx;
  font-weight: 700;
  color: #2563EB;
  line-height: 1;
}

.score-full {
  font-size: 30rpx;
  color: #9CA3AF;
  margin-left: 8rpx;
}

.score-grade-badge {
  width: 80rpx;
  height: 80rpx;
  background: #EFF6FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-grade {
  font-size: 36rpx;
  font-weight: 700;
  color: #2563EB;
}

.comment-wrap {
  padding-top: 8rpx;
}

.comment-label {
  display: block;
  font-size: 26rpx;
  color: #6B7280;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.comment-content {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
}

/* 已提交提示 */
.submitted-tip {
  background: #FFFFFF;
  display: flex;
  align-items: center;
  padding: 32rpx;
  gap: 24rpx;
}

.submitted-icon {
  font-size: 60rpx;
}

.submitted-info {
  flex: 1;
}

.submitted-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #10B981;
  margin-bottom: 8rpx;
}

.submitted-date {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0 80rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
}
