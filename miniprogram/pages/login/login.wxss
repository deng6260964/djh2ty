/* pages/login/login.wxss */

.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #EFF6FF 0%, #F8FAFC 50%, #FFFFFF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

/* 顶部区域 */
.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  padding-bottom: 80rpx;
}

.logo-wrap {
  margin-bottom: 32rpx;
}

.logo-circle {
  width: 120rpx;
  height: 120rpx;
  background: #2563EB;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.3);
}

.logo-icon {
  font-size: 56rpx;
  line-height: 1;
}

.app-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: #6B7280;
}

/* 登录卡片 */
.login-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

.card-header {
  margin-bottom: 48rpx;
  text-align: center;
}

.card-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #6B7280;
}

/* 错误框 */
.error-box {
  display: flex;
  align-items: flex-start;
  background: #FEF2F2;
  border: 1rpx solid #FECACA;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
}

.error-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.error-text {
  font-size: 26rpx;
  color: #DC2626;
  line-height: 1.5;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: #2563EB;
  border-radius: 16rpx;
  border: none;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.35);
  margin-bottom: 32rpx;
}

.login-btn::after {
  border: none;
}

.login-btn.loading {
  background: #93C5FD;
  box-shadow: none;
}

.btn-text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
}

/* 提示文字 */
.hint-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #9CA3AF;
  line-height: 1.6;
}

/* 底部 */
.login-footer {
  margin-top: auto;
  padding: 48rpx 0 80rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #D1D5DB;
  text-align: center;
}
