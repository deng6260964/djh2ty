/* pages/progress/progress.wxss */

.page-container {
  background: #F8FAFC;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 科目 Tab */
.subject-tabs-wrap {
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 16rpx;
}

.subject-tabs {
  width: 100%;
  white-space: nowrap;
}

.tabs-inner {
  display: flex;
  padding: 0 16rpx;
  align-items: center;
}

.subject-tab {
  display: inline-flex;
  align-items: center;
  padding: 24rpx 24rpx;
  position: relative;
  flex-shrink: 0;
}

.subject-tab-text {
  font-size: 28rpx;
  color: #9CA3AF;
  font-weight: 500;
}

.subject-tab.active .subject-tab-text {
  color: #2563EB;
  font-weight: 600;
}

.subject-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #2563EB;
  border-radius: 4rpx 4rpx 0 0;
}

/* 图表卡片 */
.chart-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin: 0 24rpx 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.card-subtitle {
  font-size: 24rpx;
  color: #2563EB;
  background: #EFF6FF;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

/* 骨架屏 */
.skeleton {
  background: linear-gradient(90deg, #E5E7EB 25%, #F3F4F6 50%, #E5E7EB 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
  display: block;
}

.chart-skeleton {
  width: 100%;
}

.chart-placeholder {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* Canvas */
.grade-canvas {
  width: 100%;
  display: block;
  border-radius: 8rpx;
  background: #FAFAFA;
}

.grade-canvas-legacy {
  width: 100%;
  display: none;
}

/* 最近成绩横向列表 */
.recent-scores {
  display: flex;
  overflow-x: auto;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F3F4F6;
  gap: 16rpx;
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
  padding: 12rpx 8rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.score-date {
  font-size: 20rpx;
  color: #9CA3AF;
  margin-bottom: 4rpx;
}

.score-name {
  font-size: 18rpx;
  color: #9CA3AF;
  margin-bottom: 4rpx;
  text-align: center;
}

.score-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #2563EB;
}

/* 图表空状态 */
.chart-empty {
  text-align: center;
  padding: 48rpx 0;
}

.chart-empty-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 知识点卡片 */
.knowledge-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin: 0 24rpx 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 统计徽标 */
.stats-badges {
  display: flex;
  gap: 12rpx;
}

.stat-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
}

.stat-badge.mastered {
  background: #ECFDF5;
}

.stat-badge.learning {
  background: #EFF6FF;
}

.stat-badge.todo {
  background: #F3F4F6;
}

.stat-num {
  font-size: 26rpx;
  font-weight: 700;
}

.stat-badge.mastered .stat-num {
  color: #10B981;
}

.stat-badge.learning .stat-num {
  color: #2563EB;
}

.stat-badge.todo .stat-num {
  color: #9CA3AF;
}

.stat-label {
  font-size: 18rpx;
  color: #9CA3AF;
}

/* 知识点骨架 */
.kp-skeleton {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.sk-kp-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.sk-kp-text {
  flex: 1;
  height: 28rpx;
}

.sk-kp-status {
  width: 80rpx;
  height: 28rpx;
}

/* 知识点列表项 */
.knowledge-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
  gap: 20rpx;
}

.knowledge-item:last-child {
  border-bottom: none;
}

.kp-status-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.kp-status-symbol {
  font-size: 24rpx;
  font-weight: 700;
}

.kp-info {
  flex: 1;
}

.kp-name {
  display: block;
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.kp-chapter {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
}

.kp-status-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.kp-status-text {
  font-size: 22rpx;
  font-weight: 500;
}

/* 知识点空状态 */
.knowledge-empty {
  padding: 48rpx 0;
  text-align: center;
}

.knowledge-empty-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 整体空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0 80rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
}
