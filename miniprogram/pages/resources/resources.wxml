<!-- pages/resources/resources.wxml -->
<view class="page-container">

  <!-- 科目分类标签栏 -->
  <view class="subject-filter-wrap">
    <scroll-view scroll-x class="subject-filter" enhanced>
      <view class="filter-inner">
        <view
          wx:for="{{subjects}}"
          wx:key="index"
          class="filter-tag {{activeSubject === item ? 'active' : ''}}"
          bindtap="switchSubject"
          data-subject="{{item}}"
        >
          <text class="filter-tag-text">{{item}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 加载骨架 -->
  <view wx:if="{{loading}}" class="list-content">
    <view class="skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="index">
      <view class="skeleton-row">
        <view class="skeleton sk-icon"></view>
        <view class="skeleton-info">
          <view class="skeleton sk-name"></view>
          <view class="skeleton sk-meta"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 资料列表 -->
  <view wx:elif="{{filteredList.length > 0}}" class="list-content">
    <!-- 数量提示 -->
    <view class="list-count">
      <text class="count-text">共 {{filteredList.length}} 份资料</text>
    </view>

    <view
      wx:for="{{filteredList}}"
      wx:key="id"
      class="resource-card"
      bindtap="handleFile"
      data-id="{{item.id}}"
      data-is-image="{{item.isImage}}"
      data-download-url="{{item.downloadUrl}}"
      data-filename="{{item.displayName}}"
      data-file-type="{{item.file_type}}"
    >
      <!-- 文件类型图标 -->
      <view class="file-icon-wrap" style="background: {{item.fileTypeColor}}18;">
        <text class="file-icon-text" style="color: {{item.fileTypeColor}};">{{item.fileTypeIcon}}</text>
      </view>

      <!-- 文件信息 -->
      <view class="file-info">
        <text class="file-name">{{item.displayName || item.title}}</text>

        <view class="file-meta-row">
          <!-- 科目标签 -->
          <view class="subject-mini-badge" wx:if="{{item.subject}}">
            <text class="subject-mini-text">{{item.subject}}</text>
          </view>
          <text class="file-size">{{item.fileSizeStr}}</text>
          <text class="file-date">{{item.sharedDateStr}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="file-action">
        <view wx:if="{{downloadingMap[item.id]}}" class="action-loading">
          <text class="loading-dot">...</text>
        </view>
        <view wx:else class="action-btn">
          <text class="action-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more-wrap">
      <view wx:if="{{isLoadingMore}}" class="loading-more">
        <text class="loading-text">加载中...</text>
      </view>
      <view wx:elif="{{!hasMore}}" class="no-more">
        <text class="no-more-text">已显示全部资料</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!loading}}" class="empty-state">
    <text class="empty-icon">📁</text>
    <text class="empty-title">暂无学习资料</text>
    <text class="empty-desc">老师还未分享资料，请耐心等待</text>
  </view>

</view>
